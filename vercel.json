{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots.txt"
    },
    {
      "source": "/((?!api/.*|_next/.*|assets/.*|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}

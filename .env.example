# GROQ_API_KEY: Required for Groq AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudflare API Token for integrations
CLOUDFLARE_API_TOKEN=

# =========================================================================
# Google Services & Workspace API Configuration (Sheets & Drive Integration)
# =========================================================================
# Google Service Account Email (e.g., service-account@project.iam.gserviceaccount.com)
GOOGLE_SERVICE_AC=

# Google Service Account Private Key (Include full string with \n character separators)
GOOGLE_PRIVATE_KE=

# Target Google Sheets Spreadsheet ID for order syncing and ledger logs
GOOGLE_ORDERS_SH=



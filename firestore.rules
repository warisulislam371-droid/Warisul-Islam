rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Collection: Users
    match /users/{userId} {
      allow read, write: if true;
    }

    // Collection: Vendors
    match /vendors/{vendorId} {
      allow read, write: if true;
    }

    // Collection: Products
    match /products/{productId} {
      allow read, write: if true;
    }

    // Collection: Orders
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Collection: RFQs (Request For Quotes)
    match /rfqs/{rfqId} {
      allow read, write: if true;
    }

    // Collection: Quotations
    match /quotations/{quotationId} {
      allow read, write: if true;
    }

    // Collection: Tickets
    match /tickets/{ticketId} {
      allow read, write: if true;
    }

    // Collection: Blogs
    match /blogs/{blogId} {
      allow read, write: if true;
    }

    // Collection: Notifications
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // Collection: Reviews
    match /reviews/{reviewId} {
      allow read, write: if true;
    }

    // Collection: Payment Settings
    match /payment_settings/{settingId} {
      allow read, write: if true;
    }

    // Collection: WhatsApp Settings
    match /whatsapp_settings/{settingId} {
      allow read, write: if true;
    }

    // Collection: WhatsApp Click Logs
    match /whatsapp_click_logs/{logId} {
      allow read, write: if true;
    }

    // Collection: Clearance Requests
    match /clearance_requests/{requestId} {
      allow read, write: if true;
    }

    // Collection: Promo Banners
    match /promo_banners/{bannerId} {
      allow read, write: if true;
    }

    // Collection: Commission Settings
    match /commission_settings/{settingId} {
      allow read, write: if true;
    }

    // Collection: Categories
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    // Collection: Brands
    match /brands/{brandId} {
      allow read, write: if true;
    }

    // Collection: Category Requests
    match /categoryRequests/{requestId} {
      allow read, write: if true;
    }

    // Collection: Brand Requests
    match /brandRequests/{requestId} {
      allow read, write: if true;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow read, write on all collections for unauthenticated clients
    // because the application handles its own user sessions/roles client-side
    // and does not integrate Firebase Authentication.
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /vendors/{vendorId} {
      allow read, write: if true;
    }
    
    match /products/{productId} {
      allow read, write: if true;
    }
    
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    match /rfqs/{rfqId} {
      allow read, write: if true;
    }
    
    match /quotations/{quotationId} {
      allow read, write: if true;
    }
    
    match /tickets/{ticketId} {
      allow read, write: if true;
    }
    
    match /blogs/{blogId} {
      allow read, write: if true;
    }
    
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    
    match /reviews/{reviewId} {
      allow read, write: if true;
    }
    
    match /payment_settings/{settingId} {
      allow read, write: if true;
    }
    
    match /whatsapp_settings/{settingId} {
      allow read, write: if true;
    }
    
    match /whatsapp_click_logs/{logId} {
      allow read, write: if true;
    }
    
    match /clearance_requests/{requestId} {
      allow read, write: if true;
    }
    
    match /promo_banners/{bannerId} {
      allow read, write: if true;
    }
    
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    
    match /brands/{brandId} {
      allow read, write: if true;
    }
    
    match /categoryRequests/{requestId} {
      allow read, write: if true;
    }
    
    match /brandRequests/{requestId} {
      allow read, write: if true;
    }
  }
}

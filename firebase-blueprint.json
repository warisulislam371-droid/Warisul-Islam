      },
      "required": ["categoryName", "vendorId", "status"]
    },
    "brandRequests": {
      "title": "Vendor Brand Requests",
      "description": "Requests from vendors to register new medical brands",
      "type": "object",
      "properties": {
        "brandName": { "type": "string" },
        "country": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "status": { "type": "string" },
        "requestedAt": { "type": "string" }
      },
      "required": ["brandName", "vendorId", "status"]
